# --- Base de datos ---
# Dev local: archivo libSQL en la raíz del repo. Si dejas DATABASE_URL sin definir,
# @kaypi/db resuelve automáticamente a  file:<raíz-del-repo>/kaypi.db  (cero credenciales).
# DATABASE_URL=file:./kaypi.db

# Turso (nube / producción): descomenta y rellena.
# DATABASE_URL=libsql://<tu-db>.turso.io
# DATABASE_AUTH_TOKEN=

# --- Auth ---
# Secreto para firmar la sesión (JWT). En producción usa un valor largo y aleatorio.
# En dev, si no lo defines, se usa un secreto por defecto.
AUTH_SECRET=dev-secret-cambiar-en-produccion

# --- Kiosco offline (embedded replica · se configura en el PC del kiosco) ---
# El kiosco lee/escribe un SQLite local y sincroniza con la DB central de Turso.
# KIOSCO_SYNC_URL=libsql://<tu-db>.turso.io
# KIOSCO_LOCAL_DB=file:./kiosco-replica.db

# Identidad del kiosco en este PC. El branch KIOSCO de /api/checkin lo lee para
# verificar que la oficina del input coincida y para etiquetar el replay cache.
# En dev local el seed crea 'kio_cdmx_01' y 'kio_lima_01' — elige uno.
KIOSCO_ID=kio_cdmx_01
